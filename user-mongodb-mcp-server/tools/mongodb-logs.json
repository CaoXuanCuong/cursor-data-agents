{
  "name": "mongodb-logs",
  "description": "Returns the most recent logged mongod events",
  "arguments": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "enum": [
          "global",
          "startupWarnings"
        ],
        "default": "global",
        "description": "The type of logs to return. Global returns all recent log entries, while startupWarnings returns only warnings and errors from when the process started."
      },
      "limit": {
        "type": "integer",
        "maximum": 1024,
        "minimum": 1,
        "default": 50,
        "description": "The maximum number of log entries to return."
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "logs": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "totalLinesWritten": {
        "type": "number"
      },
      "shownCount": {
        "type": "number"
      }
    },
    "required": [
      "logs",
      "totalLinesWritten",
      "shownCount"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}