{
  "name": "list-collections",
  "description": "List all collections for a given database",
  "arguments": {
    "type": "object",
    "properties": {
      "database": {
        "type": "string",
        "description": "Database name"
      }
    },
    "required": [
      "database"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "collections": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "totalCount": {
        "type": "number"
      }
    },
    "required": [
      "collections",
      "totalCount"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}