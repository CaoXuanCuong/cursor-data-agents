{
  "name": "collection-storage-size",
  "description": "Gets the size of the collection",
  "arguments": {
    "type": "object",
    "properties": {
      "database": {
        "type": "string",
        "description": "Database name"
      },
      "collection": {
        "type": "string",
        "description": "Collection name"
      }
    },
    "required": [
      "database",
      "collection"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "size": {
        "type": "number"
      },
      "units": {
        "type": "string"
      }
    },
    "required": [
      "size",
      "units"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}