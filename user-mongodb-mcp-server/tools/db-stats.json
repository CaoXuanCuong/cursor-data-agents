{
  "name": "db-stats",
  "description": "Returns statistics that reflect the use state of a single database",
  "arguments": {
    "type": "object",
    "properties": {
      "database": {
        "type": "string",
        "description": "Database name"
      }
    },
    "required": [
      "database"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "stats": {
        "type": "object",
        "additionalProperties": {}
      }
    },
    "required": [
      "stats"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}